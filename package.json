{
  "name": "falsekin",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write 'src/**/*.{ts,svelte,css}' index.html",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "svelte": "^5.53.0",
    "svelte-check": "^4.4.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "marked": "^14.0.0"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "all",
    "printWidth": 100,
    "plugins": ["prettier-plugin-svelte"],
    "overrides": [
      { "files": "*.svelte", "options": { "parser": "svelte" } }
    ]
  }
}
